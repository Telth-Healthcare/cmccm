{
  "version": 2,
  "builds": [
    {
      "src": "natlife/natlife/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "projectRoot": "natlife",
        "installCommand": "pip install -r requirements/local.txt"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "natlife/natlife/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "natlife.config.local",
    "PYTHONPATH": "natlife"
  }
}