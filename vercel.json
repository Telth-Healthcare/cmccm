{
  "version": 2,
  "builds": [
    {
      "src": "natlife/natlife/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "natlife/natlife/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "natlife.settings.local",
    "PYTHONPATH": "natlife"
  }
}